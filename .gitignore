# ===========================================================================
# .gitignore  —  tells Git which files to NOT track / upload
# ===========================================================================
# We don't need any of these in our repo. Most are auto-generated junk.

# Vercel's local build/config folder
.vercel

# Operating-system clutter
.DS_Store        # macOS folder metadata
Thumbs.db        # Windows image cache
desktop.ini      # Windows folder settings

# Editor folders
.vscode/
.idea/

# Node dependencies (we don't use any, but this is here just in case)
node_modules/

.vercel

# Private job-application material — keep OFF the public site.
LETTER.html
LETTER.md
weaviate-challenge.html
weaviate-technical-challenge-jonathan-estephan.pdf
